# ClawGuild - Environment Variables

# Base L2 RPC URL (use Alchemy, Infura, or public)
BASE_RPC_URL=https://mainnet.base.org

# Private key for the treasury wallet (DO NOT COMMIT THIS!)
# This wallet will hold escrowed funds and send payouts
TREASURY_PRIVATE_KEY=your_private_key_here

# USDC Contract on Base
USDC_CONTRACT=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Treasury Wallet Address
TREASURY_ADDRESS=0xYourTreasuryWalletAddress

# Optional: Block explorer API key for transaction verification
BASESCAN_API_KEY=your_basescan_api_key
